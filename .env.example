# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://jalanaman:jalanaman@localhost:5432/jalanaman

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Backend server ────────────────────────────────────────────────────────────
PORT=8080
FRONTEND_URL=http://localhost:3000
RUST_LOG=jalan_aman_backend=debug,tower_http=debug

# ── Web Push / VAPID ─────────────────────────────────────────────────────────
# Generate with: ./scripts/generate_vapid_keys.sh
VAPID_PUBLIC_KEY=YOUR_VAPID_PUBLIC_KEY_BASE64URL
VAPID_PRIVATE_KEY_PEM=-----BEGIN EC PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END EC PRIVATE KEY-----

# ── Email (SOS alert) ─────────────────────────────────────────────────────────
# Gmail: aktifkan 2FA → App Passwords → generate password untuk "Mail"
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM=JalanAman SOS <sos@jalanaman.id>

# ── WhatsApp Cloud API (SOS auto-send) ────────────────────────────────────────
# Official automatic WhatsApp delivery must go through WhatsApp Business Cloud API.
# Create a template with one body parameter {{1}} for the full SOS alert text.
# If template name is empty, backend tries a normal text message; Meta may reject it
# outside a customer-service conversation window.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TEMPLATE_NAME=jalanaman_sos_alert
WHATSAPP_TEMPLATE_LANGUAGE=id
WHATSAPP_GRAPH_API_VERSION=v23.0
